      "license": "MIT",
      "author": {
        "name": "Victor Villegas",
        "email": "victor.villegas@tuta.com"
      },
      "homepage": "https://github.com/V-Songbird/slag/tree/main/assay",
      "repository": "https://github.com/V-Songbird/slag",
      "category": "quality",
      "keywords": [
        "rules",
        "CLAUDE.md",
        "audit",
