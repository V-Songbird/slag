{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "slag",
  "description": "Experimental agentic plugins and tools that are not meant for public consumption.",
  "owner": {
    "name": "Victor Villegas",
    "email": "victor.villegas@tuta.com"
  },
  "plugins": [
    {
      "name": "verity",
      "source": "./verity",
      "description": "Fetches current official Claude Code documentation on demand, giving Claude truth-grounding from primary sources instead of training memory.",
      "version": "0.1.3-alpha",
      "license": "MIT",
      "author": {
        "name": "Victor Villegas",
        "email": "victor.villegas@tuta.com"
      },
      "homepage": "https://github.com/V-Songbird/slag/tree/main/verity",
      "repository": "https://github.com/V-Songbird/slag",
      "category": "reference",
      "keywords": [
        "documentation",
        "grounding",
        "truth",
        "fetch",
        "Claude Code docs",
        "MCP tools",
        "reference",
        "live fetch"
      ],
      "tags": [
        "documentation",
        "grounding",
        "truth",
        "fetch",
        "Claude Code docs",
        "MCP tools",
        "reference",
        "live fetch"
      ],
      "strict": true
    },
    {
      "name": "jetbrains-router",
      "source": "./jetbrains-router",
      "description": "Routes Claude's reads, searches, and edits through your running JetBrains IDE for live error detection, unsaved-change visibility, and index-aware search.",
      "version": "2.0.3-alpha",
      "license": "MIT",
      "author": {
        "name": "Victor Villegas",
        "email": "victor.villegas@tuta.com"
      },
      "homepage": "https://github.com/V-Songbird/slag/tree/main/jetbrains-router",
      "repository": "https://github.com/V-Songbird/slag",
      "category": "integration",
      "keywords": [
        "JetBrains",
        "WebStorm",
        "Rider",
        "IntelliJ",
        "PyCharm",
        "IDE",
        "MCP",
        "routing",
        "diagnostics",
        "hooks"
      ],
      "tags": [
        "JetBrains",
        "WebStorm",
        "Rider",
        "IntelliJ",
        "PyCharm",
        "IDE",
        "MCP",
        "routing",
        "diagnostics",
        "hooks"
      ],
      "strict": true
    },
    {
      "name": "assay",
      "source": "./assay",
      "description": "Grades every rule in CLAUDE.md and .claude/rules/ for structural clarity — can Claude tell when it fires and what to do? — then offers rewrites for the weak ones and flags rules that should be hooks, skills, or subagents instead of prose.",
      "version": "0.2.0-alpha",
      "license": "MIT",
      "author": {
        "name": "Victor Villegas",
        "email": "victor.villegas@tuta.com"
      },
      "homepage": "https://github.com/V-Songbird/slag/tree/main/assay",
      "repository": "https://github.com/V-Songbird/slag",
      "category": "quality",
      "keywords": [
        "rules",
        "CLAUDE.md",
        "audit",
        "quality",
        "instructions",
        "scoring",
        "hooks",
        "placement"
      ],
      "tags": [
        "rules",
        "CLAUDE.md",
        "audit",
        "quality",
        "instructions",
        "scoring",
        "hooks",
        "placement"
      ],
      "strict": true
    }
  ],
  "renames": {
    "forge": null
  }
}
